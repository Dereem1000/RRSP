# Local database copy (recommended — travels with the v2 folder)
DATABASE_PATH=./data/computer_dynamics.db

# REQUIRED for production: generate a random 32+ character secret (never commit .env)
# Example: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=generate-a-strong-random-secret-min-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Next.js UI (port 3000). API routes are proxied to Express — see CD_API_* below.
PORT=3000

# Express API — all /api/* business routes (apps/api on port 4000).
# Next.js rewrites /api/:path* to CD_API_ORIGIN; keep these for local dev and production.
CD_API_ORIGIN=http://127.0.0.1:4000
CD_API_PORT=4000
CD_API_HOST=127.0.0.1

# License activation system SQLite database
LICENSE_DB_PATH=./license_activation_system_new/instance/license_system.db

# Bearer token for external MSP sync (Python license GUI).
# Manage in portal Settings → Integrations → License GUI sync token.
# Optional: set MSP_API_TOKEN here only if you need a .env override (not recommended).
# MSP_API_TOKEN=

# Google reCAPTCHA v2 for public forms and login (optional — prefer Settings → Integrations)
# RECAPTCHA_SITE_KEY=your-site-key
# RECAPTCHA_SECRET_KEY=your-secret-key

# Public portal URL used in welcome emails, invoices, quotes, etc.
# Use your live domain — not 0.0.0.0 or localhost when sending client emails.
NEXT_PUBLIC_SITE_URL=https://computerdynamicstt.com

# Public demo URL (login page "Go to demo" — always https://demo.<your-domain>, not localhost)
# Optional override:
# NEXT_PUBLIC_DEMO_PORTAL_URL=https://demo.computerdynamicstt.com

# WiPay online payments (client portal Pay button)
WIPAY_ENABLED=true
WIPAY_ACCOUNT_NUMBER=your-wipay-account-number
WIPAY_API_KEY=your-wipay-api-key
# live or sandbox
WIPAY_ENVIRONMENT=live
# customer_pay, merchant_absorb, or split
WIPAY_FEE_STRUCTURE=customer_pay
