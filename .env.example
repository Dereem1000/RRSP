# Local database copy (recommended — travels with the v2 folder)
DATABASE_PATH=./data/computer_dynamics.db

# Must match v1 during migration so existing sessions/tokens work
JWT_SECRET=supersecretkey
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# API (Next.js runs on port 3000 — single app)
PORT=3000

# License activation system SQLite database
LICENSE_DB_PATH=./license_activation_system_new/instance/license_system.db

# Bearer token for external MSP sync (Python license GUI)
MSP_API_TOKEN=change-me-in-production

# Public portal URL used in welcome emails, invoices, quotes, etc.
# Use your live domain — not 0.0.0.0 or localhost when sending client emails.
NEXT_PUBLIC_SITE_URL=https://computerdynamicstt.com

# WiPay online payments (client portal Pay button)
WIPAY_ENABLED=true
WIPAY_ACCOUNT_NUMBER=7728147200
WIPAY_API_KEY=your-wipay-api-key-after-regeneration
# live or sandbox
WIPAY_ENVIRONMENT=live
# customer_pay, merchant_absorb, or split
WIPAY_FEE_STRUCTURE=customer_pay
