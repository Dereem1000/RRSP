{
  "name": "lawfirm-server",
  "version": "1.1.0",
  "description": "Backend server for Law Firm Management System",
  "main": "dist/index.js",
  "scripts": {
    "test": "jest --coverage",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc && npm run copy-assets",
    "build:prod": "npm run build && (npm audit --production || exit 0)",
    "copy-assets": "node -e \"const fs = require('fs'); const path = require('path'); fs.mkdirSync('dist/database/migrations', {recursive: true}); fs.mkdirSync('dist/services', {recursive: true}); fs.copyFileSync('src/database/schema.sql', 'dist/database/schema.sql'); fs.copyFileSync('src/index-bootstrap.js', 'dist/index-bootstrap.js'); const migrations = fs.readdirSync('src/database/migrations'); migrations.forEach(f => fs.copyFileSync(path.join('src/database/migrations', f), path.join('dist/database/migrations', f))); const services = fs.readdirSync('src/services').filter(f => f.endsWith('.js')); services.forEach(f => fs.copyFileSync(path.join('src/services', f), path.join('dist/services', f)));\"",
    "start": "node dist/index-bootstrap.js",
    "security:audit": "npm audit --production",
    "db:backup": "ts-node src/scripts/db-manage.ts backup",
    "db:restore": "ts-node src/scripts/db-manage.ts restore",
    "db:list-backups": "ts-node src/scripts/db-manage.ts list-backups",
    "db:migrate": "ts-node src/scripts/db-manage.ts migrate",
    "db:migrations": "ts-node src/scripts/db-manage.ts migrations",
    "db:check-036": "ts-node src/scripts/check-migration-036.ts",
    "db:export": "ts-node src/scripts/db-manage.ts export",
    "db:stats": "ts-node src/scripts/db-manage.ts stats",
    "db:cleanup": "ts-node src/scripts/db-manage.ts cleanup",
    "clean-duplicates": "ts-node src/scripts/clean-duplicates.ts",
    "clean-duplicates:execute": "ts-node src/scripts/clean-duplicates.ts --execute",
    "find-duplicates": "ts-node src/scripts/find-all-duplicates.ts",
    "clean-filenames": "ts-node src/scripts/clean-filenames.ts",
    "clean-filenames:execute": "ts-node src/scripts/clean-filenames.ts --execute",
    "clear-storage": "ts-node src/scripts/clear-storage.ts",
    "clear-storage:all": "ts-node src/scripts/clear-storage.ts --clear-documents",
    "clear-encrypted": "ts-node src/scripts/clear-encrypted-storage.ts",
    "encrypt-existing": "ts-node src/scripts/encrypt-existing-files.ts",
    "reset-system": "ts-node src/scripts/reset-system.ts",
    "reset-system:full": "ts-node src/scripts/reset-system.ts --full",
    "capture-role-permissions": "ts-node src/scripts/capture-role-permissions.ts",
    "list-documents": "ts-node src/scripts/list-documents.ts",
    "corrupt-file": "ts-node src/scripts/corrupt-file-for-testing.ts",
    "clear-corrupted": "ts-node src/scripts/clear-corrupted-files.ts",
    "test-archive-corruption": "ts-node src/scripts/test-archive-corruption-workflow.ts",
    "fix-columns": "ts-node src/scripts/add-missing-columns.ts",
    "classify-documents": "ts-node src/scripts/classify-documents.ts",
    "test-classification": "ts-node src/scripts/test-classification.ts",
    "test-ocr-classification": "ts-node src/scripts/test-ocr-classification.ts",
    "resend-invoice": "ts-node src/scripts/resend-invoice.ts",
    "fix-invoice-statuses": "ts-node src/scripts/fix-invoice-statuses.ts",
    "db:encrypt": "ts-node src/scripts/migrate-to-encrypted.ts",
    "db:verify-encryption": "ts-node src/scripts/verify-encryption.ts",
    "backup:full": "ts-node src/scripts/disaster-backup.ts",
    "restore:full": "ts-node src/scripts/disaster-restore.ts"
  },
  "dependencies": {
    "@journeyapps/sqlcipher": "^5.3.1",
    "@types/tesseract.js": "^0.0.2",
    "@types/uuid": "^10.0.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "groq-sdk": "^0.37.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.12",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "sqlite3": "^5.0.2",
    "tesseract.js": "^6.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.14",
    "@types/sqlite3": "^3.1.11",
    "cacache": "^20.0.3",
    "jest": "^30.2.0",
    "node-gyp": "^12.1.0",
    "nodemon": "^3.0.2",
    "tar": "^7.5.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
