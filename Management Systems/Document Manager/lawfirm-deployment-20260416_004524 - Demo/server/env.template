# Server Configuration Template
# Copy this to server/.env and fill in your values
# See docs/SECURITY_IMPLEMENTATION/ENV_VS_VAULT_REFERENCE.md for what belongs in .env vs vault.

# Server Configuration
PORT=5002
NODE_ENV=production

# Client URL (for email verification links)
CLIENT_URL=https://zccal.online.com

# Cloudflare/Proxy Configuration
# Set to true when Cloudflare is configured
BEHIND_PROXY=true
BEHIND_CLOUDFLARE=true
HTTPS_ENABLED=false

# Database (path created on first start)
DATABASE_PATH=./data/lawfirm.db

# Vault connection (hostname only, e.g. localhost – not a URL)
# Used by vault.config.ts, encryptionManager.ts, settings.ts.
VAULT_URL=localhost
VAULT_PORT=3333
# VAULT_MASTER_PASSWORD: set at runtime (PM2 env or shell), NOT in this file.
# Optional: VAULT_USE_HTTPS=false when vault runs HTTP; VAULT_CA_CERT=./certs/server.crt
# Optional: VAULT_ENABLED=true or ENCRYPTION_SOURCE=VAULT to use vault for file encryption key

# JWT Secret (REQUIRED – in .env; can also be stored in vault for backup)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE-THIS-TO-A-SECURE-RANDOM-STRING

# DB encryption key (REQUIRED – store in vault, then set here or via PM2 so server can read it)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 64 hex characters. Seed into vault: master-vault: node scripts/seed-db-encryption-key.js
DB_ENCRYPTION_KEY=CHANGE-THIS-TO-A-64-CHARACTER-HEX-KEY

# File encryption: encryptionManager uses vault first, then FALLBACK_ENCRYPTION_KEY or ENCRYPTION_MASTER_KEY
ENCRYPTION_MASTER_KEY=CHANGE-THIS-TO-A-64-CHARACTER-HEX-KEY
ENCRYPTION_ENABLED=true
ENCRYPTION_AUTO_ENCRYPT=true
ENCRYPTION_CHUNK_SIZE=1048576

# Security Policy Configuration (SECURITY-FIRST SETTINGS)
# Require encryption for all file downloads (default: true in production)
# Set to 'false' to allow unencrypted files (NOT RECOMMENDED)
SECURITY_REQUIRE_ENCRYPTION=true

# Fail-secure behavior: deny access on encryption errors instead of serving unencrypted (default: true in production)
# Set to 'false' to allow fallback to unencrypted on errors (NOT RECOMMENDED)
SECURITY_FAIL_SECURE=true

# Allow legacy unencrypted files (default: false)
# Set to 'true' to allow access to files that were never encrypted (for migration purposes)
# Only recommended during migration from unencrypted to encrypted storage
SECURITY_ALLOW_LEGACY_UNENCRYPTED=false

# Optional: Direct HTTPS (if not using Cloudflare)
# SSL_KEY_PATH=/path/to/private-key.pem
# SSL_CERT_PATH=/path/to/certificate.pem

# ── Disaster Management System (DMS) ──────────────────────────────────────────
# Python executable to use when spawning the DMS runner (default: python)
DMS_PYTHON_CMD=python
# Absolute path to the DMS root directory (where backup_system/ lives)
DMS_MODULE_PATH=E:/DMS
# LawFirm-held hex key part for 3-part backup encryption (32+ bytes = 64+ hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DMS_LAWFIRM_KEY_PART=CHANGE-THIS-TO-A-64-CHARACTER-HEX-KEY
# URL of the Mini-2026 AI system's key-part endpoint
DMS_AI_KEY_PART_URL=http://localhost:6789/api/dms/key-part
# Shared secret sent to Mini-2026 when fetching the AI key part at backup time
# Must match DMS_KEY_PART_SECRET set in Mini-2026's environment
DMS_AI_KEY_PART_SECRET=CHANGE-THIS-TO-A-SECURE-RANDOM-STRING

