# License server (optional). Default is http://127.0.0.1:5001 (local Flask server).
# If local is unreachable, the app automatically tries the fallback URL.
# For local dev, use start-dev.bat (sets both URLs to localhost) and run:
#   F:\Computer Dynamics System v2\start.bat
# first so the license API is listening on port 5001.
#
# LICENSE_SERVER_URL=http://127.0.0.1:5001
# LICENSE_SERVER_FALLBACK_URL=http://127.0.0.1:5001
#
# Production (start-production.bat) uses https://api.computerdynamicstt.com
# Do NOT use start-production.bat for local testing — HTTP 530 means Cloudflare
# cannot reach the production origin, not a bad serial number.

# PORT=8000
# SESSION_SECRET=your-secret
