# Restaurant System — Environment Configuration Template
# =========================================================
# Copy this file to .env and fill in your values.
# The .env file must NEVER be committed to version control.
#
# Run setup_secrets.py to generate a .env automatically:
#   python setup_secrets.py
#
# What stays in .env (runtime state — survives updates):
#   SECRET_KEY, any future DB credentials, mail config
#
# What is safe to replace during updates (deployable code):
#   All .py source files, templates/, static/
# =========================================================


# ── Flask Session & License Cache Integrity ───────────────────────────────────
# Signs browser session cookies and the offline license cache HMAC.
# A compromised key allows session forgery — treat it like a password.
#
# REQUIRED. Must be at least 32 characters. No two installations should share
# the same value.
#
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
SECRET_KEY=CHANGE-THIS-TO-A-SECURE-RANDOM-HEX-STRING


# ── Flask Runtime Environment ─────────────────────────────────────────────────
# Set to 'production' on live deployments.
# 'development' enables the interactive debugger (never use in production).
#
FLASK_ENV=production


# ── Server Bind Address & Port ────────────────────────────────────────────────
# HOST: 0.0.0.0 listens on all interfaces (LAN accessible).
#       Use 127.0.0.1 to restrict to localhost only.
# PORT: default 5000. Change if another service occupies this port.
#
HOST=0.0.0.0
PORT=5000
