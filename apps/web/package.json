{
  "name": "@cd-v2/web",
  "version": "2.1.1",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev": "node --max-old-space-size=8192 ../../node_modules/next/dist/bin/next dev -H 0.0.0.0 -p 3000",
    "dev:turbo": "node --max-old-space-size=8192 ../../node_modules/next/dist/bin/next dev --turbo -H 0.0.0.0 -p 3000",
    "dev:showcase": "node --max-old-space-size=8192 ../../node_modules/next/dist/bin/next dev -H 0.0.0.0",
    "build": "node --max-old-space-size=8192 ../../node_modules/next/dist/bin/next build",
    "start": "node --max-old-space-size=4096 ../../node_modules/next/dist/bin/next start -p 3000",
    "start:showcase": "node --max-old-space-size=4096 ../../node_modules/next/dist/bin/next start -H 0.0.0.0",
    "lint": "next lint"
  },
  "dependencies": {
    "@cd-v2/backup": "*",
    "@cd-v2/database": "*",
    "@cd-v2/security": "*",
    "bcryptjs": "^2.4.3",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.5.0",
    "html5-qrcode": "^2.3.8",
    "imap": "0.8.17",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.511.0",
    "mailparser": "^3.9.9",
    "next": "^15.3.3",
    "nodemailer": "^8.0.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.21",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3"
  }
}
